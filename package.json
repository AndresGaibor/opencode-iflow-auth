{
  "name": "@asframe/opencode-iflow-auth",
  "version": "1.1.0",
  "description": "OpenCode plugin for iFlow.cn - Access Qwen, DeepSeek, Kimi, GLM-5 models with OAuth 2.0, API Key, and CLI Proxy support - Auto model discovery & smart routing",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "bun run tsc -p tsconfig.build.json",
    "format": "bun run prettier --write --no-config --no-semi --single-quote --trailing-comma none --print-width 100 'src/**/*.ts'",
    "typecheck": "bun run tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "iflow",
    "glm-5",
    "qwen",
    "deepseek",
    "kimi",
    "ai",
    "auth",
    "oauth",
    "apikey",
    "cli-proxy"
  ],
  "author": "asframe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asframe/opencode-iflow-auth.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@iflow-ai/iflow-cli-sdk": "^0.2.2",
    "@opencode-ai/plugin": "^1.2.6",
    "proper-lockfile": "^4.1.2",
    "tiktoken": "^1.0.17",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^20.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "prettier": "^3.4.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "typescript": "^5.7.3"
  },
  "trustedDependencies": [
    "@iflow-ai/iflow-cli-sdk",
    "tiktoken"
  ],
  "opencode": {
    "type": "plugin",
    "hooks": [
      "auth",
      "event",
      "chat.headers"
    ]
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ]
}
